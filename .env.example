# ============================================
# PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to GitHub!

# Application Environment
NODE_ENV=production
PORT=5000

# Database - Get from Supabase Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-us-west-2.pooler.supabase.com:5432/postgres?schema=public

# JWT Secret - Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-64-character-hex-string-here
JWT_EXPIRE=7d

# Deriv API - Get from https://deriv.com/api
DERIV_API_URL=wss://ws.binaryws.com/websockets/v3
DERIV_APP_ID=your-deriv-app-id-here

# Encryption Key - Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-string-here

# Logging
LOG_LEVEL=info

# ============================================
# PHASE 2: SECURITY HARDENING
# ============================================

# SERVER CONFIGURATION
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deriv_trading_saas
DB_USER=postgres
DB_PASSWORD=your_secure_database_password_here
DB_POOL_MAX=5
DB_POOL_MIN=1

# ============================================
# AUTHENTICATION & JWT
# ============================================
JWT_SECRET=your_minimum_32_character_random_secret_key_here
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d
BCRYPT_ROUNDS=10

# ============================================
# DERIV API CREDENTIALS
# ============================================
DERIV_APP_ID=your_deriv_app_id_here
DERIV_API_URL=wss://ws.binaryws.com/websockets/v3
DERIV_API_TOKEN=your_deriv_api_token_here

# ============================================
# ENCRYPTION KEYS (for sensitive data)
# ============================================
ENCRYPTION_KEY=your_32_character_hex_encryption_key_here
IV_KEY=your_16_character_hex_initialization_vector_here

# ============================================
# CORS & SECURITY
# ============================================
CORS_ORIGIN=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING
# ============================================
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=30

# ============================================
# OPTIONAL: AWS/STORAGE CONFIGURATION
# ============================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# S3_BUCKET_NAME=your_s3_bucket_name

# ============================================
# OPTIONAL: EMAIL CONFIGURATION
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@yourdomain.com

# ============================================
# OPTIONAL: MONITORING & ANALYTICS
# ============================================
# SENTRY_DSN=your_sentry_dsn_url
# NEW_RELIC_LICENSE_KEY=your_new_relic_key

# ============================================
# INSTRUCTIONS:
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Update .env with your actual values
# 3. NEVER commit .env to Git
# 4. Use strong, random values for all secrets
# 5. Generate secrets with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# ============================================
