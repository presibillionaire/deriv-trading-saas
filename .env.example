# ============================================
# PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to GitHub!

# Application Environment
NODE_ENV=production
PORT=5000

# Database - Get from Supabase Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-us-west-2.pooler.supabase.com:5432/postgres?schema=public

# JWT Secret - Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-64-character-hex-string-here
JWT_EXPIRE=7d

# Deriv API - Get from https://deriv.com/api
DERIV_API_URL=wss://ws.binaryws.com/websockets/v3
DERIV_APP_ID=your-deriv-app-id-here

# Encryption Key - Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-string-here

# Logging
LOG_LEVEL=info
